# Choose one or both providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=
MODEL=gemini-2.5-flash
TAVILY_API_KEY=

AGENT_TOOL_TIMEOUT_SECONDS=15
AGENT_TOOL_MAX_RETRIES=1
AGENT_TOOL_RETRY_BACKOFF_SECONDS=0.25
AGENT_LLM_TIMEOUT_SECONDS=20
AGENT_MAX_ITERATIONS=6
AGENT_MEMORY_MAX_MESSAGES=10
AGENT_MEMORY_MAX_CHARACTERS=12000
# Comma-separated allowlisted roots. Empty disables document search.
AGENT_DOCUMENT_ROOTS=

# Default model
DEFAULT_MODEL=claude-sonnet-4-20250514
# DEFAULT_MODEL=gpt-4o

# Logging
LOG_LEVEL=INFO

# AI Hook Logging (set by instructor)
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=f3p1dEOhD_z8qjjtbeCtb2t9ASMEliz-4juZfWe3ZPgCtPZp-LjWthBfeNU8d5dP
AI_LOG_DIR=.ai-log

# Application Config
APP_NAME=Autonomous Drones
APP_ENV=development
APP_DEBUG=True
# Comma-separated when multiple frontend deployments need API access.
FRONTEND_ORIGIN=http://localhost:3000

# API Config
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api

POSTGRES_USER=example_user
POSTGRES_PASSWORD=example_password
POSTGRES_DB=example_db
POSTGRES_PORT=5432
POSTGRES_HOST=127.0.0.1

REDIS_PASSWORD=example_password
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
